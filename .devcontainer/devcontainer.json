{
  "name": "IPAM/VLAN Manager Demo",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "postCreateCommand": "pip install -r requirements.txt && python3 seed_demo.py",
  "postStartCommand": "python3 ipam-web.py demo.db --host 0.0.0.0 --port 8080 -- --bios &",

  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "IPAM Web UI",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
